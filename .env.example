# VisionQA Environment Configuration
# Copy this file to .env and fill in the values

# Google Cloud & GenAI
GOOGLE_API_KEY=your_gemini_api_key_here
GCS_BUCKET=visionqa-baselines

# Vision Engine
CONFIDENCE_THRESHOLD=0.85

# Workflow Automator (Optional)
JIRA_WEBHOOK_URL=
SLACK_WEBHOOK_URL=

# Application Settings
DEBUG=True
PORT=8080
